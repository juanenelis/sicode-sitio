rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Formularios de contacto / inscripción del sitio principal
    match /inscripciones/{id} { allow read, write: if true; }
    match /escritores/{id}    { allow read, write: if true; }
    match /comentarios/{id}   { allow read, write: if true; }

    // Certificados
    match /cert/{id} { allow read, write: if true; }

    // Sistema de formularios múltiples (Formularios.jsx)
    match /formdef/{id}  { allow read, write: if true; }
    match /formresp/{id} { allow read, write: if true; }

    // Aula Virtual
    match /aula_data/{id}       { allow read, write: if true; } // centro + chats
    match /aula_usuarios/{id}   { allow read, write: if true; }
    match /aula_cursos/{id}     { allow read, write: if true; }
    match /aula_biblioteca/{id} { allow read, write: if true; }
    match /aula_grupos/{id}     { allow read, write: if true; }
    match /aula_alertas/{id}    { allow read, write: if true; }
  }
}
